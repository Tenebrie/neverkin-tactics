; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NeverkinTactics"
run/main_scene="uid://br6t7ri07sgw2"
config/features=PackedStringArray("4.8", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://biovk6eljcdma"

[autoload]

PerformanceUtilsInstance="*uid://dghocsyibug02"
GlobalControls="*uid://bc0txfe5vmcja"
CombatUI="*uid://bpsu16vmy2ald"
NavmeshManagerInstance="*uid://cdt3nwgodl7ts"
TurnManagerInstance="*uid://dq3q74togyfy3"
GameInstance="*uid://dge7jpvygd3jf"
MessageLogInstance="*uid://bnowp6ttp38gb"
NPCManagerInstance="*uid://b75fcywcxv6fi"
PhysicsFieldVisualizationLayer="*uid://dmgwfsk6pj2ai"
ActorValueVisualizationLayer="*uid://xfb867ura4t"
LineOfSightVisualizationLayer="*uid://c4kmoemm6iqu1"
CoverVisualizationLayer="*uid://cd5xxxahr1i53"
ProximityVisualizationLayer="*uid://blafccyolmd7y"
KeywordManagerInstance="*uid://r6w3dqxegpf3"
SoundManagerInstance="*uid://b6pnvjt3k267k"

[debug]

gdscript/type_inference/infer_type_from_assignment=true
gdscript/warnings/unused_signal=0
gdscript/warnings/shadowed_variable=0
gdscript/warnings/shadowed_variable_base_class=0
gdscript/warnings/redundant_await=0
shapes/navigation/3d/enable_edge_lines=false

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/stretch/scale=1.5

[dotnet]

project/assembly_name="NeverkinTactics"

[editor_plugins]

enabled=PackedStringArray("res://addons/script-ide/plugin.cfg")

[global_group]

navigation_mesh_source_group=""

[input]

fastForwardAnimations={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}
endTurn={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194309,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
lockParadoxTooltip={
