; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NeverkinTactics"
run/main_scene="uid://br6t7ri07sgw2"
config/features=PackedStringArray("4.8", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GlobalControls="*uid://bc0txfe5vmcja"
CombatUI="*uid://bpsu16vmy2ald"
NavmeshManagerInstance="*uid://cdt3nwgodl7ts"
TurnManagerInstance="*uid://dq3q74togyfy3"
GameInstance="*uid://dge7jpvygd3jf"
MessageLogInstance="*uid://bnowp6ttp38gb"
NPCManagerInstance="*uid://b75fcywcxv6fi"
PhysicsFieldVisualizationLayer="*uid://dmgwfsk6pj2ai"
ActorValueVisualizationLayer="*uid://xfb867ura4t"
LineOfSightVisualizationLayer="*uid://c4kmoemm6iqu1"
CoverVisualizationLayer="*uid://cd5xxxahr1i53"
ProximityVisualizationLayer="*uid://blafccyolmd7y"

[debug]

gdscript/type_inference/infer_type_from_assignment=true
gdscript/warnings/shadowed_variable=0
shapes/navigation/3d/enable_edge_lines=false

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/stretch/scale=1.5

[dotnet]

project/assembly_name="NeverkinTactics"

[editor_plugins]

enabled=PackedStringArray("res://addons/script-ide/plugin.cfg")

[global_group]

navigation_mesh_source_group=""

[layer_names]

3d_physics/layer_2="Layer 2 - Actor"
3d_physics/layer_9="Layer 9 - Low Cover"
3d_physics/layer_10="Layer 10 - High Cover"
3d_physics/layer_11="Layer 11 - Full Cover"

[navigation]

3d/warnings/navmesh_cell_size_mismatch=false
3d/default_cell_size=0.00999999999999999
3d/default_cell_height=0.00999999999999999

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/16_bits=false
anti_aliasing/quality/msaa_3d=2
