; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NeverkinTactics"
run/main_scene="uid://br6t7ri07sgw2"
config/features=PackedStringArray("4.8", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GlobalControls="*uid://bc0txfe5vmcja"
CombatUI="*uid://bpsu16vmy2ald"
NavmeshManager="*uid://cdt3nwgodl7ts"

[debug]

gdscript/type_inference/infer_type_from_assignment=true
shapes/navigation/3d/enable_edge_lines=false

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/stretch/scale=1.5

[dotnet]

project/assembly_name="NeverkinTactics"

[editor_plugins]

enabled=PackedStringArray("res://addons/asset-plugin/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[global_group]

navigation_mesh_source_group=""

[navigation]

3d/warnings/navmesh_cell_size_mismatch=false
3d/default_cell_size=0.00999999999999999
3d/default_cell_height=0.00999999999999999

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
anti_aliasing/quality/msaa_3d=2
