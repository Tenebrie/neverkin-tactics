[sub_resource type="Shader" id="Shader_61go4"]
code = "shader_type canvas_item;

uniform float radius : hint_range(0.0, 256.0) = 48.0;

void fragment() {
	vec2 size = 1.0 / TEXTURE_PIXEL_SIZE;        // texture size in pixels
	vec2 pos = UV * size;
	vec2 corner = min(pos, size - pos);          // dist to nearest edge per axis
	if (corner.x < radius && corner.y < radius) {
		float d = length(vec2(radius) - corner);
		COLOR.a *= 1.0 - smoothstep(radius - 1.0, radius + 1.0, d);
	}
}"

