[resource]
script = ExtResource("1_6txya")
name = "Infuse (X)"
category = "Keyword"
description = "Spend extra [color=orange]X[/color] mana to alter the effect of a skill in some way.

If not specified otherwise, [color=orange]X[/color] is [color=orange]1[/color].

[color=orange]Usage:[/color] Press the skill button once to select it, then again to switch to infused version. Press again to deselect."
aliases = Array[String](["Infuse", "Infuse 1", "Infuse 2", "Infuse 3", "Infuse 4"])
