script = ExtResource("1_futex")
name = "Pierce (X)"
category = "Keyword"
description = "This projectile passes through the first [color=orange]X[/color] targets in its path, hitting each one, before stopping. Walls and other obstacles still block it.

If not specified otherwise, [color=orange]X[/color] is [color=orange]1[/color]."
