[resource]
script = ExtResource("1_u1cst")
name = "Wolfpack"
category = "Faction"
description = "A militarized mercenary company based in $Veridian. Formed in 2085 shortly after the fall of the $syndicates, the Wolfpack seized the opportunity and declared $Northshore an area under their protection.
They are a common sight in different parts of the city though as the Wolves are commonly hired as bouncers, thugs or security"
