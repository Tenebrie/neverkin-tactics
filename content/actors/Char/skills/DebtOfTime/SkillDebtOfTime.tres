[resource]
script = ExtResource("1_mmpl8")
Name = "Debt of Time"
Category = 3
Description = "Turn time itself into a weapon. Target all enemies in an area. For each combined AP they have, reduce cooldown on your left-most ability on cooldown by 1 and drain 1 AP from the enemy. Stop when no abilities other than this one are on cooldown, or when all enemies have no AP left."
IconTexture = ExtResource("1_0hhfb")
ManaCost = 2
Cooldown = 2
TargetingMaxRange = 10.0
metadata/_custom_type_script = "uid://bbecckeuc1ovf"
