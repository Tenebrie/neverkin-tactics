[resource]
script = ExtResource("1_skdef")
Name = "Rain of Feathers"
Category = 2
Description = "Spin around, dealing %Damage damage and applying $Bleeding to enemies in range.

If you have an enemy gripped with $Griffon Grip, use them as a blunt weapon instead of your wings. Do not apply $Bleeding.

For each character or %GrabbedVictimWallsPerDamage wall segments hit, the victim takes %GrabbedVictimDamage damage."
IconTexture = ExtResource("1_ws3td")
TargetingMaxRange = 1.0
