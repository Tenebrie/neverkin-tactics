[resource]
script = ExtResource("1_skdef")
Name = "Headbutt"
Category = 2
Description = "Dash forward, dealing %PrimaryDamage damage and pushing one target up to %{PushDist}m away with powerful force.

If the pushed target hits any obstacle, it takes an extra %SecondaryDamage damage and receives $Stunned, while the obstacles take %BonkDamage damage.

$Demolish: Use the debris as projectiles instead, with each destroyed wall segment dealing %BonkDamage damage to the first target hit."
IconTexture = ExtResource("1_fb2my")
TargetingMaxRange = 5.0
